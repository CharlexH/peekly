{
  "name": "whoshere",
  "version": "1.0.0",
  "description": "Self-hosted, privacy-friendly web analytics",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:tracker": "node scripts/build-tracker.js",
    "db:init": "wrangler d1 execute whoshere --local --file=./schema.sql",
    "db:seed": "wrangler d1 execute whoshere --local --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250313.0",
    "terser": "^5.37.0",
    "typescript": "^5.8.0",
    "vitest": "~3.0.0",
    "wrangler": "^4.5.0"
  }
}
